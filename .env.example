# ============================================================
# Apex Moto Powersport Marketplace — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ---- DATABASE -----------------------------------------------
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Supabase example (Transaction pooler - recommended for Render):
#   postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Supabase example (Direct connection):
#   postgresql://postgres:[db-password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://username:password@localhost:5432/apexmoto

# ---- SESSION SECRET ------------------------------------------
# Long random string used to sign session cookies.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=replace_with_a_long_random_secret_string_at_least_32_chars

# ---- NODE ENVIRONMENT ----------------------------------------
# Set to "production" on Render (enables secure cookies, etc.)
NODE_ENV=production

# ---- PORT ----------------------------------------------------
# Render sets this automatically. Leave as-is for Render deploys.
# For local dev, the API server defaults to 3000 if not set.
PORT=3000

# ============================================================
# RENDER DEPLOYMENT GUIDE
# ============================================================
# 1. Create a new Web Service on Render pointing to this repo.
# 2. Set "Build Command":  pnpm install && pnpm --filter @workspace/api-server run build
# 3. Set "Start Command":  pnpm --filter @workspace/api-server run start
# 4. Add the following Environment Variables in Render dashboard:
#
#    DATABASE_URL   — Your PostgreSQL URL (Supabase, Render DB, etc.)
#    SESSION_SECRET — A long random secret (generate with openssl rand -base64 32)
#    NODE_ENV       — production
#
# 5. After first deploy, run database migrations:
#    In the Render shell:  DATABASE_URL=<your-url> pnpm --filter @workspace/db run push
#
# For the frontend (bike-marketplace), deploy as a Static Site:
#    Build Command:  pnpm install && pnpm --filter @workspace/bike-marketplace run build
#    Publish dir:    artifacts/bike-marketplace/dist
#    Set env var:    VITE_API_URL=https://your-api-service.onrender.com
# ============================================================
