# ============================================================
# ApexMoto Powersport Marketplace — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://username:password@localhost:5432/apexmoto

# Session Secret — use a long random string (32+ characters)
# Generate one with: openssl rand -base64 32
SESSION_SECRET=replace_with_a_long_random_secret_string

# Node environment
NODE_ENV=production

# Port the API server listens on (Render sets this automatically)
PORT=3000
