# ============================================================
# Apex Moto Powersport Marketplace — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ---- DATABASE (Neon PostgreSQL) ----------------------------
# Get your connection string from https://neon.tech dashboard.
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxx.neon.tech/neondb?sslmode=require

# ---- SESSION SECRET ------------------------------------------
# Long random string used to sign session cookies.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=replace_with_a_long_random_secret_string_at_least_32_chars

# ---- NODE ENVIRONMENT ----------------------------------------
# Set to "production" on Render (enables secure cookies, etc.)
NODE_ENV=production

# ---- PORT ----------------------------------------------------
# Render sets this automatically. Leave as-is for Render deploys.
# For local dev, the API server defaults to 3000 if not set.
PORT=3000

# ---- SUPABASE STORAGE (file uploads) -------------------------
# Used only for image/file uploads via Supabase Storage.
# Database is Neon — Supabase is used only as a CDN for uploads.
# Get these from: Supabase project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- FRONTEND API URL ----------------------------------------
# The public URL of the deployed API server.
# Required when the frontend and backend are on different domains
# (e.g. Render static site + Render web service).
# Leave empty for local development (relative URLs are used).
VITE_API_URL=https://your-api-service.onrender.com

# ============================================================
# RENDER DEPLOYMENT GUIDE
# ============================================================
#
# --- Backend (API Server) ---
# Service type:    Web Service
# Build Command:   pnpm install && pnpm --filter @workspace/api-server run build
# Start Command:   pnpm --filter @workspace/api-server run start
# Environment Variables to set in Render dashboard:
#   DATABASE_URL          — Neon PostgreSQL connection string
#   SESSION_SECRET        — Long random secret (openssl rand -base64 32)
#   SUPABASE_URL          — Supabase project URL (for file storage)
#   SUPABASE_SERVICE_ROLE_KEY — Supabase service role key
#   NODE_ENV              — production
#
# After first deploy, push DB schema to Neon:
#   In the Render shell: pnpm --filter @workspace/db run push
#
# --- Frontend (Static Site) ---
# Service type:    Static Site
# Build Command:   pnpm install && pnpm --filter @workspace/bike-marketplace run build
# Publish dir:     artifacts/bike-marketplace/dist/public
# Environment Variables to set in Render dashboard:
#   VITE_API_URL          — https://your-api-service.onrender.com
#   BASE_PATH             — /
#
# ============================================================
